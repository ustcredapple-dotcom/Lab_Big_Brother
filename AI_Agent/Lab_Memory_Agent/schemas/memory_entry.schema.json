{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Memory Entry",
  "type": "object",
  "required": ["id", "title", "type", "status", "date", "source_refs", "summary"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,80}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["notebook_page", "document", "experiment", "protocol", "result", "decision", "meeting", "dataset", "code", "instrument", "idea", "hypothesis"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "superseded", "archived"]
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "projects": {
      "type": "array",
      "items": { "type": "string" }
    },
    "people": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "superseded_by": {
      "type": "array",
      "items": { "type": "string" }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
